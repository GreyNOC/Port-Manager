{
  "name": "greynoc-port-manager",
  "version": "0.3.0",
  "description": "Standalone Electron desktop utility for viewing localhost ports, tracking server uptime, and safely stopping selected local dev servers.",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "desktop": "electron .",
    "dev": "electron .",
    "check": "node --check lib/scanner.js && node --check lib/state.js && node --check lib/manager.js && node --check electron/main.js && node --check electron/preload.js",
    "dist": "electron-builder",
    "dist:dir": "electron-builder --dir"
  },
  "keywords": [
    "localhost",
    "ports",
    "developer-tools",
    "electron",
    "greynoc"
  ],
  "author": "GreyNOC",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "electron": "^41.5.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.greynoc.portmanager",
    "productName": "GreyNOC Port Manager",
    "files": [
      "electron/**/*",
      "public/**/*",
      "lib/**/*",
      "package.json",
      "assets/**/*",
      "README.md",
      "LICENSE"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Development"
    }
  }
}
